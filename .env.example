# OpenAI API Key (required for GPT-4o)
OPENAI_API_KEY=sk-your-key-here

# OpenClaw Gateway
OPENCLAW_GATEWAY_URL=ws://localhost:18789
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here

# Bridge Server
BRIDGE_PORT=3001
BRIDGE_HOST=0.0.0.0

# SQLite Database Path (shared between plugin and bridge server)
TASK_DB_PATH=./data/tasks.sqlite
